;; signal-agent — ordinary working wire contract for the `agent` LLM-call component.
;;
;; Wire-only: schema-emitted Input/Output/Event roots + rkyv + optional NOTA codec on the
;; signal-frame streaming envelope. Runtime, the provider registry, the HTTPS provider call,
;; storage, and sockets live in the `agent` daemon, never here.
;;
;; SCOPE (psyche f8k7, iucr): `agent` is an LLM-API-call component. It makes provider HTTP
;; API calls in an OpenAI-compatible chat-completions style. It is NOT an agent-harness front
;; door — harness backends (Claude Code / Codex / Pi sessions) are deferred and absent here.
;;
;; The ordinary contract is the single-shot + streaming call surface a peer (the gated Spirit
;; guardian) uses to ask a configured provider to complete a prompt. Adding a provider is pure
;; configuration in `meta-signal-agent` (endpoint + model + key handle) — never a change here.

{}

[Call (StreamCall StreamCall opens CompletionStream) CancelStream]
[(Completed Completion) (CallRejected CallRejection) (StreamOpened StreamOpening) (StreamCancelled StreamCancellation) RequestUnimplemented (Event AgentEvent)]
{
  SystemText String
  UserText String
  AssistantText String
  ModelName String
  ProviderName String
  StreamToken Integer
  TokenDelta String
  DeltaSequence Integer
  TemperatureMilli Integer
  MaximumOutputTokens Integer
  CompletionText String
  StopReasonText String
  PromptTokenCount Integer
  CompletionTokenCount Integer
  RejectionDetail String

  ;; A turn in the chat transcript. Closed roles; no free-form string role.
  ChatRole [System User Assistant]
  ChatMessage { role.ChatRole text.UserText }
  ChatTranscript (Vector ChatMessage)

  ;; The output shaping the guardian wants: free-form text, or a NOTA response —
  ;; the model emits one valid NOTA expression directly (no JSON translation). The
  ;; daemon injects a NOTA instruction, validates the completion parses as NOTA,
  ;; and retries once before rejecting, so the guardian gets a typed NOTA verdict.
  OutputMode [FreeText Nota]

  ;; Reasoning controls for thinking-capable providers (DeepSeek V4 and peers).
  ;; A deliberate judge — the Spirit guardian — asks for thinking enabled at high
  ;; effort; ordinary callers leave both unset for the provider default. Typed
  ;; value enums, never stringly-typed knobs, so the wire carries the closed set.
  ReasoningEffort [Low Medium High]
  ThinkingMode [Enabled Disabled]

  PromptOptions {
    Model.(Optional ModelName)
    Provider.(Optional ProviderName)
    TemperatureMilliSelection.(Optional TemperatureMilli)
    MaximumOutputTokensSelection.(Optional MaximumOutputTokens)
    OutputMode
    ReasoningEffortSelection.(Optional ReasoningEffort)
    ThinkingModeSelection.(Optional ThinkingMode)
  }

  ;; A Prompt carries a system message, the user transcript, and call options. The
  ;; system text is optional because some providers reject an empty system turn.
  Prompt {
    System.(Optional SystemText)
    ChatTranscript
    PromptOptions
  }

  TokenUsage {
    PromptTokens.(Optional PromptTokenCount)
    CompletionTokens.(Optional CompletionTokenCount)
  }

  ;; One single-shot call.
  Call Prompt
  ;; The same call, streamed: the daemon pushes TokenDelta events on the opened
  ;; CompletionStream, then a terminal CompletionDelta with stop reason.
  StreamCall Prompt
  CancelStream StreamToken

  ;; The single-shot reply.
  Completion {
    CompletionText
    stop_reason.StopReasonText
    TokenUsage
  }

  CallRejectionReason [
    NoProviderConfigured
    ProviderUnreachable
    ProviderRejected
    OutputModeUnsupported
    InvalidNotaOutput
    DaemonUnconfigured
  ]
  CallRejection { reason.CallRejectionReason detail.RejectionDetail }

  StreamOpening StreamToken
  StreamCancellation StreamToken

  OperationKind [Call StreamCall CancelStream]
  UnimplementedReason [NotInPrototypeScope]
  RequestUnimplemented { operation.OperationKind reason.UnimplementedReason }

  ;; Stream events on CompletionStream: token deltas, then one terminal delta that
  ;; closes the transcript with the stop reason and usage.
  TokenStreamDelta { token.StreamToken sequence.DeltaSequence delta.TokenDelta }
  CompletionStreamDelta { token.StreamToken stop_reason.StopReasonText TokenUsage }

  AgentEvent [
    (TokenStreamDelta TokenStreamDelta belongs CompletionStream)
    (CompletionStreamDelta CompletionStreamDelta belongs CompletionStream)
  ]
  CompletionStream (Stream { token.StreamToken opened.StreamOpening event.AgentEvent close.StreamToken })
}
